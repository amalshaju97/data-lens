# ─── Data Lens · Environment Config ───────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Required: your OpenAI API key
OPENAI_API_KEY=sk-...

# Optional: model to use (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Optional: number of synthetic rows per table sent to the AI (default: 12)
SYNTHETIC_ROWS=12

# Optional: path to the SQLite database file (default: data_lens.db)
DB_PATH=data_lens.db
